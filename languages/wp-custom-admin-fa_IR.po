#. Settings — tabs & section headings.
msgid "Branding"
msgstr "برندسازی"

msgid "Colors"
msgstr "رنگ‌ها"

msgid "Login"
msgstr "ورود"

msgid "Menu"
msgstr "منو"

msgid "White-label"
msgstr "وایت‌لیبل"

msgid "Tools"
msgstr "ابزارها"

msgid "Color palette"
msgstr "پالت رنگ"

msgid "Login page"
msgstr "صفحهٔ ورود"

msgid "Admin menu"
msgstr "منوی مدیریت"

msgid "Data"
msgstr "داده‌ها"

msgid "Export"
msgstr "برون‌بری"

msgid "Import"
msgstr "درون‌ریزی"

msgid "Brand control panel"
msgstr "پنل کنترل برند"

#. Settings — Branding tab.
msgid "Enable the custom admin theme"
msgstr "فعال‌سازی پوستهٔ اختصاصی مدیریت"

msgid "Master switch for the admin reskin and brand colors."
msgstr "کلید اصلی برای پوستهٔ مدیریت و رنگ‌های برند."

msgid "Product name"
msgstr "نام محصول"

msgid "Shown in the menu, footer and login. Leave blank to use the site name."
msgstr "در منو، پاورقی و صفحهٔ ورود نمایش داده می‌شود. برای استفاده از نام سایت خالی بگذارید."

msgid "Admin logo"
msgstr "لوگوی مدیریت"

msgid "Displayed at the top of the admin sidebar."
msgstr "در بالای نوار کناری مدیریت نمایش داده می‌شود."

msgid "Font"
msgstr "قلم"

msgid "System default"
msgstr "پیش‌فرض سیستم"

msgid "Monospace"
msgstr "تک‌فاصله"

msgid "Custom Home dashboard"
msgstr "پیشخوان خانهٔ اختصاصی"

msgid "Adds a branded Home screen in place of the default WordPress dashboard."
msgstr "یک صفحهٔ خانهٔ برندشده به‌جای پیشخوان پیش‌فرض وردپرس اضافه می‌کند."

msgid "Land on Home after login"
msgstr "نمایش صفحهٔ خانه پس از ورود"

msgid "Redirect the default dashboard to the branded Home screen."
msgstr "پیشخوان پیش‌فرض را به صفحهٔ خانهٔ برندشده هدایت می‌کند."

msgid "Color scheme"
msgstr "طرح رنگ"

msgid "Auto (match the system)"
msgstr "خودکار (هماهنگ با سیستم)"

msgid "Light"
msgstr "روشن"

msgid "Dark"
msgstr "تیره"

msgid "Applies a dark theme to the admin content and the Home dashboard."
msgstr "یک پوستهٔ تیره به محتوای مدیریت و پیشخوان خانه اعمال می‌کند."

msgid "Activity chart in the dashboard header"
msgstr "نمودار فعالیت در سربرگ پیشخوان"

msgid "Shows a 14-day activity trend chart when there is recent data."
msgstr "هنگام وجود دادهٔ اخیر، نمودار روند فعالیت ۱۴ روزه را نشان می‌دهد."

#. Settings — Colors tab.
msgid "Primary"
msgstr "اصلی"

msgid "Buttons, links and active states."
msgstr "دکمه‌ها، پیوندها و حالت‌های فعال."

msgid "Primary (hover)"
msgstr "اصلی (هاور)"

msgid "Accent"
msgstr "تأکید"

msgid "Sidebar background"
msgstr "پس‌زمینهٔ نوار کناری"

msgid "Sidebar text"
msgstr "متن نوار کناری"

msgid "Sidebar active item"
msgstr "آیتم فعال نوار کناری"

msgid "Top bar background"
msgstr "پس‌زمینهٔ نوار بالا"

#. Settings — Login tab.
msgid "Brand the login screen"
msgstr "برندسازی صفحهٔ ورود"

msgid "Login logo"
msgstr "لوگوی ورود"

msgid "Falls back to the admin logo when empty."
msgstr "در صورت خالی‌بودن، از لوگوی مدیریت استفاده می‌شود."

msgid "Login background"
msgstr "پس‌زمینهٔ ورود"

msgid "Logo link URL"
msgstr "نشانی پیوند لوگو"

msgid "Where the login logo links to. Defaults to the site home."
msgstr "لوگوی ورود به کجا پیوند می‌خورد. پیش‌فرض: خانهٔ سایت."

#. Settings — Menu tab.
msgid "Customize the admin menu"
msgstr "سفارشی‌سازی منوی مدیریت"

msgid "Full-access capability"
msgstr "توانایی دسترسی کامل"

msgid "Users with this capability always see the complete menu. Default: manage_options."
msgstr "کاربران دارای این توانایی همیشه کل منو را می‌بینند. پیش‌فرض: manage_options."

msgid "Renaming applies to everyone. Hiding applies only to users without the full-access capability. Hiding is cosmetic — it does not restrict direct URL access."
msgstr "تغییر نام برای همه اعمال می‌شود. پنهان‌سازی فقط برای کاربران بدون توانایی دسترسی کامل اعمال می‌شود. پنهان‌سازی ظاهری است و دسترسی مستقیم با نشانی را محدود نمی‌کند."

msgid "Drag rows to reorder the menu. The chosen order is applied to everyone; newly added plugin menus appear after ordered items."
msgstr "برای مرتب‌سازی منو، ردیف‌ها را بکشید. ترتیب انتخابی برای همه اعمال می‌شود؛ منوهای افزونه‌های جدید پس از آیتم‌های مرتب‌شده نمایش داده می‌شوند."

msgid "Reorder"
msgstr "مرتب‌سازی"

msgid "Menu item"
msgstr "آیتم منو"

msgid "Hide (non-admins)"
msgstr "پنهان (غیرمدیران)"

msgid "Rename to"
msgstr "تغییر نام به"

msgid "No admin menu items were detected."
msgstr "هیچ آیتم منوی مدیریتی یافت نشد."

#. Settings — White-label tab.
msgid "Enable white-labeling"
msgstr "فعال‌سازی وایت‌لیبل"

msgid "Remove the WordPress logo from the toolbar"
msgstr "حذف لوگوی وردپرس از نوار ابزار"

msgid "Remove the \"Howdy,\" greeting"
msgstr "حذف عبارت خوش‌آمدگویی «Howdy»"

msgid "Hide the dashboard welcome panel"
msgstr "پنهان‌کردن پنل خوش‌آمد پیشخوان"

msgid "Hide the WordPress events & news widget"
msgstr "پنهان‌کردن ابزارک رویدادها و اخبار وردپرس"

msgid "Hide the default dashboard widgets"
msgstr "پنهان‌کردن ابزارک‌های پیش‌فرض پیشخوان"

msgid "Hide the WordPress version in the footer"
msgstr "پنهان‌کردن نسخهٔ وردپرس در پاورقی"

msgid "Hide update notices from non-admins"
msgstr "پنهان‌کردن اعلان‌های به‌روزرسانی از غیرمدیران"

msgid "Users who can update core still see them."
msgstr "کاربرانی که می‌توانند هستهٔ وردپرس را به‌روزرسانی کنند همچنان آن‌ها را می‌بینند."

msgid "Hide Screen Options for non-admins"
msgstr "پنهان‌کردن «تنظیمات صفحه» برای غیرمدیران"

msgid "Footer text"
msgstr "متن پاورقی"

msgid "Replaces the WordPress footer credit. Basic links allowed. Blank uses the product name."
msgstr "جایگزین اعتبار پاورقی وردپرس می‌شود. پیوندهای ساده مجاز است. خالی، نام محصول را نشان می‌دهد."

#. Settings — Tools tab.
msgid "Delete all settings when the plugin is uninstalled"
msgstr "حذف همهٔ تنظیمات هنگام حذف افزونه"

msgid "Off by default, so branding survives a reinstall."
msgstr "به‌صورت پیش‌فرض خاموش است تا برند پس از نصب مجدد باقی بماند."

msgid "Save changes"
msgstr "ذخیرهٔ تغییرات"

msgid "Download the current brand configuration as a JSON file to reuse on another site."
msgstr "پیکربندی فعلی برند را به‌صورت فایل JSON دانلود کنید تا در سایت دیگری استفاده شود."

msgid "Export brand.json"
msgstr "برون‌بری brand.json"

msgid "Upload a brand.json file. Imported values are validated before they are saved."
msgstr "یک فایل brand.json بارگذاری کنید. مقادیر واردشده پیش از ذخیره اعتبارسنجی می‌شوند."

msgid "Brand settings imported successfully."
msgstr "تنظیمات برند با موفقیت درون‌ریزی شد."

msgid "Import failed. Please upload a valid brand.json file."
msgstr "درون‌ریزی ناموفق بود. لطفاً یک فایل brand.json معتبر بارگذاری کنید."

#. Media picker & permission notices.
msgid "Select image"
msgstr "انتخاب تصویر"

msgid "Remove"
msgstr "حذف"

msgid "Use image"
msgstr "استفاده از تصویر"

msgid "You do not have permission to access this page."
msgstr "شما اجازهٔ دسترسی به این صفحه را ندارید."

msgid "You do not have permission to do this."
msgstr "شما اجازهٔ انجام این کار را ندارید."

#. Home dashboard — menu, KPI labels & quick actions.
msgid "Home"
msgstr "خانه"

msgid "Posts"
msgstr "نوشته‌ها"

msgid "Pages"
msgstr "برگه‌ها"

msgid "Comments"
msgstr "دیدگاه‌ها"

msgid "Users"
msgstr "کاربران"

msgid "New post"
msgstr "نوشتهٔ جدید"

msgid "New page"
msgstr "برگهٔ جدید"

msgid "Media library"
msgstr "کتابخانهٔ رسانه"

msgid "Brand settings"
msgstr "تنظیمات برند"

#. Home dashboard — hero greeting. %s is the user display name.
msgid "Welcome back, %s"
msgstr "خوش آمدید، %s"

#. Home dashboard — hero subtitle. %s is the product / site name.
msgid "Here's what's happening on %s today."
msgstr "امروز در %s چه خبر است."

msgid "View site"
msgstr "نمایش سایت"

msgid "Recent activity"
msgstr "فعالیت‌های اخیر"

msgid "Quick actions"
msgstr "اقدامات سریع"

msgid "Nothing here yet"
msgstr "هنوز چیزی اینجا نیست"

msgid "Your latest posts and pages will show up here."
msgstr "آخرین نوشته‌ها و برگه‌های شما اینجا نمایش داده می‌شوند."

msgid "Write your first post"
msgstr "اولین نوشتهٔ خود را بنویسید"

#. Home dashboard — activity timestamp. %s is a human-readable time, e.g. "2 hours".
msgid "%s ago"
msgstr "%s پیش"

msgid "Published"
msgstr "منتشرشده"

msgid "Scheduled"
msgstr "زمان‌بندی‌شده"

msgid "Draft"
msgstr "پیش‌نویس"

msgid "Pending"
msgstr "در انتظار بازبینی"

#. Multisite — network admin defaults page.
msgid "Network-wide brand defaults. Individual sites can override these in their own settings."
msgstr "پیش‌فرض‌های برند در سطح شبکه. هر سایت می‌تواند آن‌ها را در تنظیمات خود بازنویسی کند."

msgid "Network defaults saved."
msgstr "پیش‌فرض‌های شبکه ذخیره شد."
